<xml xmlns="https://developers.google.com/blockly/xml" id="toolbox" style="display: none">
  <category name="Robot Eyes" colour="#E85D24" icon="fa-eye">
    <block type="robot_setup"/>
    <block type="robot_show_square">
      <field name="SHAPE">balanced</field>
      <field name="EXPR">normal</field>
    </block>
    <block type="robot_show_oval">
      <field name="SHAPE">normal</field>
      <field name="EXPR">normal</field>
    </block>
    <block type="robot_show_custom">
      <field name="EXPR">normal</field>
      <field name="EW">28</field>
      <field name="EH">28</field>
      <field name="RX">6</field>
      <field name="PUPIL">medium</field>
    </block>
    <label text="⚠️ Diễn hoạt tức thời (chạy đến khi kết thúc)"/>
    <block type="robot_play_animation">
      <field name="ANIM">blink</field>
      <field name="TIMES">1</field>
      <field name="SPEED">1.0</field>
    </block>
    <label text="⚡ Diễn hoạt linh hoạt (chạy trong vòng lặp chính)"/>
    <block type="robot_create_animation_nb">
      <field name="ANIM">blink</field>
    </block>
    <block type="robot_update_animation_nb"/>
    <block type="robot_animate_custom">
      <field name="MODE">all</field>
    </block>
  </category>
</xml>
